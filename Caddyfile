team.tixpass.co.kr {
	encode zstd gzip

	# SSE/streaming endpoints — disable buffering and extend timeouts.
	@stream path /api/process /api/auth/start /api/auth/submit
	handle @stream {
		reverse_proxy web:3000 {
			flush_interval -1
			transport http {
				read_timeout 15m
				write_timeout 15m
			}
		}
	}

	handle {
		reverse_proxy web:3000
	}

	header {
		Strict-Transport-Security "max-age=31536000"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "no-referrer-when-downgrade"
	}
}
