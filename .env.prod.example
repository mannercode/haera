# ============================================================
# EC2 production env — copy to ./.env on the EC2 host (chmod 600)
# Do NOT commit this file once filled in.
# ============================================================

# ECR image to run. Replace with your actual ECR registry.
WEB_IMAGE=123456789012.dkr.ecr.ap-northeast-2.amazonaws.com/tixpass:team

# MongoDB Atlas (production cluster).
MONGODB_URI=mongodb+srv://USER:PASSWORD@haera-cluster.04wltu9.mongodb.net/?appName=haera-cluster
MONGODB_DB=haera

# Claude OAuth token (1-year). Run `claude setup-token` on a machine with a browser.
# Or leave empty and use the in-app login flow on first visit.
CLAUDE_CODE_OAUTH_TOKEN=

# Object storage. Defaults to bundled MinIO. For AWS S3 instead, set:
#   S3_ENDPOINT=  (empty for AWS default)
#   S3_FORCE_PATH_STYLE=false
S3_ENDPOINT=http://minio:9000
S3_REGION=ap-northeast-2
S3_BUCKET=haera
S3_ACCESS_KEY=replace-with-strong-random-32+
S3_SECRET_KEY=replace-with-strong-random-32+
S3_FORCE_PATH_STYLE=true

# Session signing key — generate: openssl rand -hex 32
SESSION_SECRET=replace-with-32-hex-chars-from-openssl-rand-hex-32

# 4-digit invite code for signup
SIGNUP_CODE=0000

# Internal token for spawned Claude → API auth — generate: openssl rand -hex 32
HAERA_INTERNAL_TOKEN=replace-with-32-hex-chars-from-openssl-rand-hex-32
