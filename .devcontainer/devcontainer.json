{
    "name": "${containerWorkspaceFolderBasename}",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "features": {
        "ghcr.io/devcontainers/features/docker-in-docker:2": {},
        "ghcr.io/devcontainers/features/github-cli:1": {}
    },
    "privileged": true,
    "runArgs": [
        "--add-host",
        "host.docker.internal:127.0.0.1",
        "--name=${localEnv:USER:unknown}-${localWorkspaceFolderBasename}"
    ],
    "remoteUser": "node",
    "mounts": [
        "source=${localEnv:HOME}/.config,target=/home/node/.config,type=bind",
        "source=${localEnv:HOME}/.ssh,target=/home/node/.ssh,type=bind",
        "source=${localEnv:HOME}/.claude,target=/home/node/.claude,type=bind",
        "source=${localEnv:HOME}/.claude.json,target=/home/node/.claude.json,type=bind"
    ],
    "initializeCommand": {
        "prepare-mounts": "mkdir -p ${localEnv:HOME}/.claude ${localEnv:HOME}/.config ${localEnv:HOME}/.ssh",
        "prepare-files": "touch ${localEnv:HOME}/.claude.json"
    },
    "forwardPorts": [],
    "customizations": {
        "vscode": {
            "extensions": [
                "dbaeumer.vscode-eslint",
                "firsttris.vscode-jest-runner",
                "ms-azuretools.vscode-docker",
                "ms-azuretools.vscode-containers",
                "esbenp.prettier-vscode",
                "mutantdino.resourcemonitor",
                "anthropic.claude-code"
            ],
            "settings": {
                "remote.autoForwardPorts": false,
                "remote.downloadExtensionsLocally": true
            }
        }
    }
}
