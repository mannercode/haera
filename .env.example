# MongoDB Atlas connection string (or self-hosted mongo URI).
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?appName=YourApp
MONGODB_DB=haera

# Optional: pre-set a Claude Code OAuth token to skip the in-app login flow.
# Generate with `claude setup-token` on a machine with a browser. ANTHROPIC_API_KEY
# is intentionally NOT used — that bills per-token; this token uses your subscription.
CLAUDE_CODE_OAUTH_TOKEN=

# Object storage. Defaults work with bundled MinIO. For AWS S3, set:
#   S3_ENDPOINT=  (leave blank for default AWS endpoint)
#   S3_REGION=ap-northeast-2
#   S3_BUCKET=haera-prod
#   S3_ACCESS_KEY=AKIA...
#   S3_SECRET_KEY=...
#   S3_FORCE_PATH_STYLE=false
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=haera
S3_ACCESS_KEY=haera
S3_SECRET_KEY=haera-dev-secret
S3_FORCE_PATH_STYLE=true

# Session cookie signing key (32+ chars). Generate with: openssl rand -hex 32
SESSION_SECRET=replace-me-with-a-32-plus-character-random-string

# 4-digit invite code required at signup. Anyone who knows this can register.
SIGNUP_CODE=0000

# Internal token used by spawned Claude processes to call back into the local API.
HAERA_INTERNAL_TOKEN=replace-me-with-random-32-plus-chars
